# --- Front (Vite) : obligatoires au build / dev client ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_ENV=

# --- API Node (Express) : Resend + même projet Supabase que le client ---
# À dupliquer sur l’hébergeur qui exécute `node dist/index.js` (ex. Railway, VPS).
# Sur Vercel avec vercel.json actuel : seul le statique est servi ; ces vars ne
# lancent pas l’API Express — il faut héberger le serveur ailleurs ou ajouter des Serverless routes.
RESEND_API_KEY=
RESEND_FROM=
SUPABASE_URL=
SUPABASE_ANON_KEY=
