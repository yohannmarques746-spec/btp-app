# --- Front (Vite) : obligatoires au build / dev client ---
# Tu peux les remplir ici ou dans client/.env : si ces lignes sont vides, le serveur
# et Vite reprennent automatiquement les VITE_* depuis client/.env.
# Même chose pour RESEND_* et SUPABASE_* (API Node) si tu les mets seulement dans client/.env.
# Si tu n’as que VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY, le serveur recopie vers SUPABASE_* automatiquement.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_ENV=

# --- API Node (Express) : Resend + même projet Supabase que le client ---
# À dupliquer sur l’hébergeur qui exécute `node dist/index.js` (ex. Railway, VPS).
# Sur Vercel avec vercel.json actuel : seul le statique est servi ; ces vars ne
# lancent pas l’API Express — il faut héberger le serveur ailleurs ou ajouter des Serverless routes.
RESEND_API_KEY=
# Adresse autorisée dans Resend : email seul ou « Nom <email@domaine> ». Si espaces, guillemets obligatoires.
RESEND_FROM=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Sécurité (nouveaux) ---
# Clé secrète pour signer les tokens CSRF. Générer avec : openssl rand -hex 32
# OBLIGATOIRE en production.
CSRF_SECRET=

# Redis pour rate limiting distribué (optionnel — fallback en-mémoire si absent)
# Format : redis://[:password@]host[:port][/db-number]
REDIS_URL=
